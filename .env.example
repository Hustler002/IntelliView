# ─── Authentication ──────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Database ────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/intelliview

# ─── Redis (BullMQ job queue) ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AWS S3 (resume/audio storage) ──────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=intelliview-uploads
AWS_REGION=us-east-1

# ─── LLM Provider ───────────────────────────────────────────────
# Options: "openai" | "gemini"
LLM_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=

# Set to "true" to log raw LLM responses (prompt debugging)
LOG_RAW_LLM=false

# ─── Speech-to-Text (future module) ─────────────────────────────
# Options: "assemblyai" | "deepgram"
STT_PROVIDER=assemblyai
ASSEMBLYAI_API_KEY=
DEEPGRAM_API_KEY=
